{
  "name": "@flazz/core",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/*.js": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "build:tsc": "tsc",
    "build": "run-s prisma:generate clean build:tsc",
    "dev": "tsc -w",
    "test": "pnpm build && node --input-type=module -e \"import { globSync } from 'glob'; import { spawnSync } from 'node:child_process'; const files = globSync('dist/**/*.test.js'); process.exit(files.length ? (spawnSync(process.execPath, ['--test', ...files], { stdio: 'inherit' }).status ?? 1) : 0)\""
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "3.0.93",
    "@ai-sdk/anthropic": "^2.0.63",
    "@ai-sdk/azure": "2.0.104",
    "@ai-sdk/cohere": "2.0.25",
    "@ai-sdk/deepinfra": "2.0.45",
    "@ai-sdk/deepseek": "2.0.29",
    "@ai-sdk/fireworks": "2.0.46",
    "@ai-sdk/google": "^2.0.53",
    "@ai-sdk/google-vertex": "3.0.127",
    "@ai-sdk/groq": "2.0.37",
    "@ai-sdk/mistral": "2.0.30",
    "@ai-sdk/openai": "^2.0.91",
    "@ai-sdk/openai-compatible": "^1.0.33",
    "@ai-sdk/perplexity": "2.0.27",
    "@ai-sdk/provider": "^2.0.1",
    "@ai-sdk/togetherai": "2.0.45",
    "@ai-sdk/xai": "2.0.66",
    "@composio/core": "^0.6.0",
    "@flazz/shared": "workspace:*",
    "@google-cloud/local-auth": "^3.0.1",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@openrouter/ai-sdk-provider": "^1.2.6",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.3.2",
    "@types/react": "^19.2.7",
    "@xmldom/xmldom": "^0.9.10",
    "ai": "^5.0.133",
    "awilix": "^12.0.5",

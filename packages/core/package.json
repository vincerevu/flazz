    "ddg-search": "^2026.2.16",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.3.0",
    "glob": "^13.0.0",
    "google-auth-library": "^10.5.0",
    "googleapis": "^169.0.0",
    "image-size": "^2.0.2",
    "isomorphic-git": "^1.29.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "markdown-it": "^14.1.0",
    "node-html-markdown": "^2.0.0",
    "ollama-ai-provider-v2": "^1.5.4",

{
    "name": "@flazz/shared",
    "private": true,
    "type": "module",
    "license": "Apache-2.0",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./src/*": "./src/*",
      "./dist/*.js": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.js"
      },
      "./dist/*": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.js"
      }
    },
    "scripts": {
      "clean": "rimraf dist",
      "build:tsc": "tsc",
      "build": "run-s clean build:tsc",
      "dev": "tsc -w"
    },
    "dependencies": {
      "zod": "^4.2.1"
    }
}

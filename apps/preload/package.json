{
  "name": "@flazz/preload",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "main": "dist/preload.js",
  "scripts": {
    "clean": "rimraf dist",
    "build:tsc": "tsc",
    "build:bundle": "esbuild dist/preload.js --bundle --platform=node --format=cjs --external:electron --outfile=dist/preload.bundle.js",
    "build:rename": "node -e \"require('fs').renameSync('dist/preload.bundle.js','dist/preload.js')\"",
    "build": "run-s clean build:tsc build:bundle build:rename"
  },
  "dependencies": {
    "@flazz/shared": "workspace:*"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "esbuild": "^0.24.2"
  }
}

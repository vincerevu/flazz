{
  "name": "@x/preload",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "main": "dist/preload.js",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc && esbuild dist/preload.js --bundle --platform=node --format=cjs --external:electron --outfile=dist/preload.bundle.js && node -e \"require('fs').renameSync('dist/preload.bundle.js','dist/preload.js')\""
  },
  "dependencies": {
    "@x/shared": "workspace:*"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "esbuild": "^0.24.2"
  }
}
